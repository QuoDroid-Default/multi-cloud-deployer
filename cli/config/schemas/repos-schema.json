{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/your-org/multi-cloud-deployer/schemas/repos",
  "title": "Repository References Schema",
  "description": "Schema for .deployer/repos.yaml - references to application repositories",
  "type": "object",
  "required": ["version", "repositories"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "repositories": {
      "type": "object",
      "description": "Application repository references",
      "properties": {
        "backend": {
          "type": "object",
          "required": ["url", "type"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Git repository URL (HTTPS or SSH)"
            },
            "type": {
              "type": "string",
              "enum": ["python-django", "nodejs-express", "ruby-rails", "java-spring"],
              "description": "Backend type"
            },
            "branch": {
              "type": "string",
              "description": "Default branch"
            },
            "ref": {
              "type": "string",
              "description": "Git tag or commit hash (overrides branch)"
            }
          }
        },
        "frontend": {
          "type": "object",
          "required": ["url", "type"],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Git repository URL (HTTPS or SSH)"
            },
            "type": {
              "type": "string",
              "enum": ["react-vite", "react-cra", "vue", "angular", "nextjs"],
              "description": "Frontend type"
            },
            "branch": {
              "type": "string",
              "description": "Default branch"
            },
            "ref": {
              "type": "string",
              "description": "Git tag or commit hash (overrides branch)"
            }
          }
        },
        "extension": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "type": {
              "type": "string",
              "enum": ["chrome-extension", "firefox-extension"]
            },
            "branch": {
              "type": "string"
            },
            "deploy": {
              "type": "boolean",
              "description": "Whether to deploy to cloud (vs. extension store only)"
            }
          }
        }
      }
    }
  }
}

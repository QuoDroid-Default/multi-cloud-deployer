[Unit]
Description=Coco TestAI ASGI Server (Daphne)
After=network.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_user }}
WorkingDirectory={{ backend_dir }}
Environment="PATH={{ backend_dir }}/venv/bin"
Environment="DJANGO_SETTINGS_MODULE={{ django_settings_module }}"
EnvironmentFile={{ backend_dir }}/.env
ExecStart={{ backend_dir }}/venv/bin/daphne -b 0.0.0.0 -p 8000 coco_testai.asgi:application
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

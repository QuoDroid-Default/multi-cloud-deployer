[Unit]
Description=Coco TestAI Celery Beat Scheduler
After=network-online.target coco-daphne.service coco-celery-worker.service
Wants=network-online.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_user }}
WorkingDirectory={{ backend_dir }}
Environment="HOME=/home/{{ app_user }}"
Environment="PATH={{ backend_dir }}/venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="DJANGO_SETTINGS_MODULE={{ django_settings_module }}"
Environment="APP_ENV={{ env_name }}"
ExecStart={{ backend_dir }}/venv/bin/celery -A copilot_orchestrator beat --loglevel=info
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

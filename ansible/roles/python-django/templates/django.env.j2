# Django Environment Configuration
# Generated by Ansible - {{ ansible_date_time.iso8601 }}

# Django Core
DEBUG=False
SECRET_KEY={{ django_secret_key }}
ALLOWED_HOSTS={{ django_allowed_hosts }}

# Database Configuration (PostgreSQL RDS)
# Django settings.py expects DB_* not DATABASE_*
DB_NAME={{ database_name }}
DB_USER={{ database_user }}
DB_PASSWORD={{ database_password }}
DB_HOST={{ database_host }}
DB_PORT={{ database_port }}

# Cache & Celery Configuration (ElastiCache Redis)
# Django settings.py expects REDIS_URL for Celery broker/backend
REDIS_URL=redis://{{ cache_host }}:{{ cache_port }}/0

# Application Settings
APP_ENV={{ env_name }}
ENVIRONMENT={{ env_name }}

# Static and Media Files
STATIC_ROOT={{ backend_dir }}/staticfiles
STATIC_URL=/static/
MEDIA_ROOT={{ backend_dir }}/media
MEDIA_URL=/media/

# Frontend/CORS Configuration
FRONTEND_URL=http://{{ ansible_host }}
WEBAPP_ORIGIN=http://{{ ansible_host }}

# CORS Origins (comma-separated list of allowed origins)
{% if cdn_domain is defined and cdn_domain %}
EXTRA_CORS_ORIGINS=http://{{ ansible_host }},https://{{ cdn_domain }}
{% else %}
EXTRA_CORS_ORIGINS=http://{{ ansible_host }}
{% endif %}

# Test Execution Configuration
TEST_EXECUTOR={{ test_executor | default('docker') }}
{% if test_executor == 'docker' %}
# Docker Executor Configuration (Non-Production)
# Uses locally built image on EC2 instance
PLAYWRIGHT_IMAGE=coco-test-runner:latest
{% elif test_executor == 'fargate' or test_executor == 'ecs' %}
# ECS Fargate Configuration (Production)
ECS_CLUSTER_NAME={{ ecs_cluster_name | default('coco-test-execution-' + env_name) }}
ECS_TASK_DEFINITION={{ ecs_task_definition | default('coco-test-runner') }}
ECS_S3_BUCKET={{ ecs_s3_bucket | default('') }}
ECS_SUBNET_IDS={{ ecs_subnet_ids | default('') }}
ECS_SECURITY_GROUPS={{ ecs_security_groups | default('') }}
AWS_DEFAULT_REGION={{ aws_region | default('ap-south-1') }}
{% endif %}
